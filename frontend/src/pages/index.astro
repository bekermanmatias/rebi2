---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard';
import OffersBanner from '../components/OffersBanner';
import RecentlyViewed from '../components/RecentlyViewed';
import { getCategories, getProducts, getBanners, getPromoCards, getBrands } from '../lib/data';

const categories = await getCategories();
const featuredProducts = await getProducts({ featured: true, limit: 4 });
const productsRaw = featuredProducts.length > 0 ? featuredProducts : await getProducts({ limit: 4 });
const products = productsRaw.slice(0, 4);
const banners = await getBanners();
const promoCards = await getPromoCards();
const brands = await getBrands();


const categoryIcons: Record<string, string> = {
  construction: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 22h20M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/></svg>`,
  paintbrush: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`,
  wrench: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"/></svg>`,
  droplet: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a8 8 0 008-8c0-4.5-8-13-8-13S4 8.5 4 13a8 8 0 008 8z"/></svg>`,
  zap: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
  palette: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z"/></svg>`,
  grid: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>`,
  home: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
  box: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`,
};

const slugToIcon: Record<string, string> = {
  'obra-gruesa': 'construction',
  'terminaciones': 'paintbrush',
  'herramientas': 'wrench',
  'plomeria': 'droplet',
  'electricidad': 'zap',
  'pinturas': 'palette',
  'pisos': 'grid',
  'cocinas': 'home',
};
---

<Layout
  title="Rebi Construcciones - Materiales para tu obra"
  description="Referentes en la comercialización de materiales para la construcción. Calidad, servicio y compromiso con cada obra."
>
  <!-- Offers banner carousel -->
  {banners.length > 0 && (
    <section>
      <OffersBanner client:load banners={banners} />
    </section>
  )}


  <!-- Featured products -->
  <section class="bg-gray-50 py-12 sm:py-16">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-extrabold uppercase italic text-gray-900 sm:text-2xl">
          Destacados de la semana
        </h2>
        <a
          href="/productos"
          class="flex items-center gap-1 text-sm font-semibold text-red-600 transition-colors hover:text-red-700"
        >
          Ver todo
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4 sm:gap-6">
        {products.map((product) => (
          <ProductCard client:load product={product} />
        ))}
      </div>
    </div>
  </section>

  <!-- Promo cards (imágenes 1.png–4.png en public) -->
  <section class="bg-gray-100 py-6 sm:py-8">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-4">
        <a href="/productos?categoria=pinturas" class="group overflow-hidden rounded-2xl shadow-sm transition-transform hover:-translate-y-1 hover:shadow-lg">
          <img src="/1.png" alt="Promo 1" class="aspect-[382/296] w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
        </a>
        <a href="/productos?categoria=plomeria" class="group overflow-hidden rounded-2xl shadow-sm transition-transform hover:-translate-y-1 hover:shadow-lg">
          <img src="/2.png" alt="Promo 2" class="aspect-[382/296] w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
        </a>
        <a href="/productos?categoria=electricidad" class="group overflow-hidden rounded-2xl shadow-sm transition-transform hover:-translate-y-1 hover:shadow-lg">
          <img src="/3.png" alt="Promo 3" class="aspect-[382/296] w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
        </a>
        <a href="/productos?categoria=pisos" class="group overflow-hidden rounded-2xl shadow-sm transition-transform hover:-translate-y-1 hover:shadow-lg">
          <img src="/4.png" alt="Promo 4" class="aspect-[382/296] w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
        </a>
      </div>
    </div>
  </section>

  <!-- Marcas destacadas -->
  {brands.length > 0 && (
    <section class="border-b border-gray-200 bg-white">
      <div class="mx-auto max-w-[1400px] px-4 py-8 sm:px-6 lg:px-8">
        <div class="mb-6 flex items-center justify-between gap-4">
          <h2 class="text-lg font-extrabold uppercase text-gray-900 sm:text-xl">
            Nuestras Marcas
          </h2>
        </div>
        <div class="brands-marquee overflow-hidden py-2">
          <div class="brands-track flex w-max items-center gap-6 sm:gap-8 lg:gap-10">
            {[...brands, ...brands].map((brand, idx) => (
              <a
                href={`/productos?marca=${brand.slug}`}
                class="group flex shrink-0 flex-col items-center"
                aria-label={brand.name}
                aria-hidden={idx >= brands.length ? 'true' : 'false'}
              >
                <div class="flex h-28 w-28 items-center justify-center overflow-hidden rounded-full border-2 border-gray-200 bg-white p-3 shadow-sm transition-all group-hover:-translate-y-0.5 group-hover:border-red-500 group-hover:shadow-md sm:h-32 sm:w-32">
                  {brand.logo_url ? (
                    <img src={brand.logo_url} alt={brand.name} class="h-full w-full object-contain" loading="lazy" />
                  ) : (
                    <span class="text-sm font-bold text-gray-400 uppercase">{brand.name.slice(0, 3)}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Sección: Cerámicos y porcelanatos -->
  <section class="bg-gray-50 py-10 sm:py-14">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-2xl font-black text-gray-900 sm:text-3xl">Cerámicos y porcelanatos</h2>
          <p class="text-lg font-bold text-red-600 sm:text-xl">Renová con lo mejor</p>
          <p class="mt-1 text-sm text-gray-500">Los mejores pisos, a un click de distancia.</p>
          <a href="/productos?categoria=pisos" class="mt-3 inline-block rounded-full bg-gray-900 px-5 py-2 text-xs font-bold uppercase tracking-wide text-white transition-colors hover:bg-gray-700">
            Pisos y revestimientos
          </a>
        </div>
        <div class="hidden overflow-hidden rounded-2xl sm:block sm:w-64 lg:w-80">
          <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?q=80&w=600&auto=format&fit=crop" alt="Cerámicos y porcelanatos" class="h-40 w-full object-cover lg:h-48" loading="lazy" />
        </div>
      </div>

      <div class="relative">
        <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4">
          <a href="/productos?categoria=pisos" class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex aspect-square items-center justify-center overflow-hidden rounded-lg bg-gray-50">
              <img src="https://images.unsplash.com/photo-1615529182904-14819c35db37?q=80&w=400&auto=format&fit=crop" alt="Laja" class="h-full w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </div>
            <div class="mt-3">
              <p class="text-sm font-bold text-gray-900 truncate">LAJA 12 46X46 1RA x CAJA</p>
              <p class="mt-0.5 text-xs text-gray-500">Su venta es Solo por caja cerr...</p>
            </div>
          </a>
          <a href="/productos?categoria=pisos" class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex aspect-square items-center justify-center overflow-hidden rounded-lg bg-gray-50">
              <img src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?q=80&w=400&auto=format&fit=crop" alt="Ceibo Beige" class="h-full w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </div>
            <div class="mt-3">
              <p class="text-sm font-bold text-gray-900 truncate">CEIBO BEIGE 20 36X36 1RA</p>
              <p class="mt-0.5 text-xs text-gray-500">Su venta es Solo por caja cerr...</p>
            </div>
          </a>
          <a href="/productos?categoria=pisos" class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex aspect-square items-center justify-center overflow-hidden rounded-lg bg-gray-50">
              <img src="https://images.unsplash.com/photo-1600607687644-c7171b42498f?q=80&w=400&auto=format&fit=crop" alt="Esmeralda" class="h-full w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </div>
            <div class="mt-3">
              <p class="text-sm font-bold text-gray-900 truncate">ESMERALDA 20 36X36 1ERA</p>
              <p class="mt-0.5 text-xs text-gray-500">Su venta es Solo por caja cerr...</p>
            </div>
          </a>
          <a href="/productos?categoria=pisos" class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex aspect-square items-center justify-center overflow-hidden rounded-lg bg-gray-50">
              <img src="https://images.unsplash.com/photo-1618220179428-22790b461013?q=80&w=400&auto=format&fit=crop" alt="Calacata" class="h-full w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </div>
            <div class="mt-3">
              <p class="text-sm font-bold text-gray-900 truncate">CALACATA BR 5 60X60 1RA</p>
              <p class="mt-0.5 text-xs text-gray-500">Su venta es solo por caja cerr...</p>
            </div>
          </a>
        </div>
      </div>

      <div class="mt-8 text-center">
        <a href="/productos?categoria=pisos" class="inline-flex items-center gap-2 rounded-full bg-gray-900 px-8 py-3 text-sm font-bold text-white transition-colors hover:bg-gray-700">
          Ver más productos
        </a>
      </div>
    </div>
  </section>

  <!-- Sección: Baño -->
  <section class="bg-white py-10 sm:py-14">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-2xl font-black text-gray-900 sm:text-3xl">Baño</h2>
          <p class="text-lg font-bold text-red-600 sm:text-xl">Renová con lo mejor</p>
          <p class="mt-1 text-sm text-gray-500">Diseño inteligente para tu hogar</p>
          <a href="/productos?categoria=plomeria" class="mt-3 inline-block rounded-full bg-gray-900 px-5 py-2 text-xs font-bold uppercase tracking-wide text-white transition-colors hover:bg-gray-700">
            Baño
          </a>
        </div>
        <div class="hidden overflow-hidden rounded-2xl sm:block sm:w-64 lg:w-80">
          <img src="https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?q=80&w=600&auto=format&fit=crop" alt="Baño" class="h-40 w-full object-cover lg:h-48" loading="lazy" />
        </div>
      </div>

      <div class="relative">
        <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4">
          <a href="/productos?categoria=plomeria" class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex aspect-square items-center justify-center overflow-hidden rounded-lg bg-gray-50">
              <img src="https://images.unsplash.com/photo-1620626011761-996317b8d101?q=80&w=400&auto=format&fit=crop" alt="Ducha PFR" class="h-full w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </div>
            <div class="mt-3">
              <p class="text-sm font-bold text-gray-900 truncate">DUCHA PFR - 021 (120 × 80)</p>
              <p class="mt-0.5 text-xs text-gray-500">Medidas: 120 × 80 × 225 cm.</p>
            </div>
          </a>
          <a href="/productos?categoria=plomeria" class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex aspect-square items-center justify-center overflow-hidden rounded-lg bg-gray-50">
              <img src="https://images.unsplash.com/photo-1584622650111-993a426fbf0a?q=80&w=400&auto=format&fit=crop" alt="Ducha S-3090" class="h-full w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </div>
            <div class="mt-3">
              <p class="text-sm font-bold text-gray-900 truncate">DUCHA S-3090 (100 × 100)</p>
              <p class="mt-0.5 text-xs text-gray-500">Medidas: 1000 × 1000 × 2150</p>
            </div>
          </a>
          <a href="/productos?categoria=plomeria" class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex aspect-square items-center justify-center overflow-hidden rounded-lg bg-gray-50">
              <img src="https://images.unsplash.com/photo-1564540583246-934409427776?q=80&w=400&auto=format&fit=crop" alt="Ducha PFR - 901" class="h-full w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </div>
            <div class="mt-3">
              <p class="text-sm font-bold text-gray-900 truncate">DUCHA PFR - 901 (90 × 90)</p>
              <p class="mt-0.5 text-xs text-gray-500">Medidas: 900 × 900 × 2150 m...</p>
            </div>
          </a>
          <a href="/productos?categoria=plomeria" class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex aspect-square items-center justify-center overflow-hidden rounded-lg bg-gray-50">
              <img src="https://images.unsplash.com/photo-1585704032915-c3400ca199e7?q=80&w=400&auto=format&fit=crop" alt="Grifería Bidet" class="h-full w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </div>
            <div class="mt-3">
              <p class="text-sm font-bold text-gray-900 truncate">GRIFERIA BIDET LINEA PUEL</p>
              <p class="mt-0.5 text-xs text-gray-500">Color: Cromo. Tipo: Monocoma...</p>
            </div>
          </a>
        </div>
      </div>

      <div class="mt-8 text-center">
        <a href="/productos?categoria=plomeria" class="inline-flex items-center gap-2 rounded-full bg-gray-900 px-8 py-3 text-sm font-bold text-white transition-colors hover:bg-gray-700">
          Ver más productos
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-gray-900 py-12 sm:py-16">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
        <div>
          <h2 class="text-2xl font-extrabold text-white sm:text-3xl">¿Necesitás un presupuesto a medida?</h2>
          <p class="mt-2 text-gray-400">Nuestros asesores técnicos te ayudan a calcular los materiales para tu obra.</p>
        </div>
        <div class="flex flex-wrap gap-4">
          <a
            href="/productos"
            class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-rebi-red)] px-6 py-3 font-semibold text-white transition-colors hover:bg-red-700"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Ver catálogo
          </a>
          <a
            href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '5491112345678'}?text=${encodeURIComponent('Hola, necesito un presupuesto para mi obra')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white px-6 py-3 font-semibold text-white transition-colors hover:bg-white hover:text-gray-900"
