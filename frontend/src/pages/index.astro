---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard';
import OffersBanner from '../components/OffersBanner';
import RecentlyViewed from '../components/RecentlyViewed';
import { getCategories, getProducts, getBanners, getPromoCards, getBrands, getHomeFeatureSection, getHomeReviews } from '../lib/data';

const categories = await getCategories();
const featuredProducts = await getProducts({ featured: true, limit: 4 });
const productsRaw = featuredProducts.length > 0 ? featuredProducts : await getProducts({ limit: 4 });
const products = productsRaw.slice(0, 4);
const banners = await getBanners();
const promoCards = await getPromoCards();
const brands = await getBrands();
const ceramicSection = await getHomeFeatureSection('ceramicos');
const ceramicImage =
  ceramicSection?.image_url ||
  'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?q=80&w=1600&auto=format&fit=crop';
const ceramicTiles = (ceramicSection?.tile_images?.length
  ? ceramicSection.tile_images
  : [
      'https://images.unsplash.com/photo-1615529182904-14819c35db37?q=80&w=500&auto=format&fit=crop',
      'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?q=80&w=500&auto=format&fit=crop',
      'https://images.unsplash.com/photo-1600607687644-c7171b42498f?q=80&w=500&auto=format&fit=crop',
      'https://images.unsplash.com/photo-1618220179428-22790b461013?q=80&w=500&auto=format&fit=crop',
    ]).slice(0, 4);
const ceramicLink = ceramicSection?.target_link || '/productos?categoria=pisos';
const shippingSection = await getHomeFeatureSection('envios-info');
const homeReviews = await getHomeReviews();
const shippingIcons = (shippingSection?.tile_images?.length
  ? shippingSection.tile_images
  : [
      'https://cdn-icons-png.flaticon.com/512/2972/2972185.png',
      'https://cdn-icons-png.flaticon.com/512/1046/1046857.png',
      'https://cdn-icons-png.flaticon.com/512/2920/2920244.png',
      'https://cdn-icons-png.flaticon.com/512/3081/3081559.png',
    ]).slice(0, 4);


const categoryIcons: Record<string, string> = {
  construction: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 22h20M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/></svg>`,
  paintbrush: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`,
  wrench: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"/></svg>`,
  droplet: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a8 8 0 008-8c0-4.5-8-13-8-13S4 8.5 4 13a8 8 0 008 8z"/></svg>`,
  zap: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
  palette: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z"/></svg>`,
  grid: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>`,
  home: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
  box: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`,
};

const slugToIcon: Record<string, string> = {
  'obra-gruesa': 'construction',
  'terminaciones': 'paintbrush',
  'herramientas': 'wrench',
  'plomeria': 'droplet',
  'electricidad': 'zap',
  'pinturas': 'palette',
  'pisos': 'grid',
  'cocinas': 'home',
};
---

<Layout
  title="Rebi Construcciones - Materiales para tu obra"
  description="Referentes en la comercialización de materiales para la construcción. Calidad, servicio y compromiso con cada obra."
>
  <!-- Offers banner carousel -->
  {banners.length > 0 && (
    <section>
      <OffersBanner client:load banners={banners} />
    </section>
  )}


  <!-- Featured products -->
  <section class="bg-gray-50 py-12 sm:py-16">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-extrabold uppercase italic text-gray-900 sm:text-2xl">
          Destacados de la semana
        </h2>
        <a
          href="/productos"
          class="flex items-center gap-1 text-sm font-semibold text-red-600 transition-colors hover:text-red-700"
        >
          Ver todo
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4 sm:gap-6">
        {products.map((product) => (
          <ProductCard client:load product={product} />
        ))}
      </div>
    </div>
  </section>

  <!-- Cards de categorías (editables desde admin) -->
  {promoCards.length > 0 && (
    <section class="bg-gray-100 py-6 sm:py-8">
      <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-4">
          {promoCards.slice(0, 4).map((card) => (
            <a
              href={card.target_link || '/productos'}
              class="group overflow-hidden rounded-2xl shadow-sm transition-transform hover:-translate-y-1 hover:shadow-lg"
              aria-label={card.title}
            >
              <img
                src={card.image_url}
                alt={card.title}
                class="aspect-[382/296] w-full object-cover transition-transform group-hover:scale-105"
                loading="lazy"
              />
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Marcas destacadas -->
  {brands.length > 0 && (
    <section class="border-b border-gray-200 bg-white">
      <div class="mx-auto max-w-[1400px] px-4 py-8 sm:px-6 lg:px-8">
        <div class="mb-6 flex items-center justify-between gap-4">
          <h2 class="text-lg font-extrabold uppercase text-gray-900 sm:text-xl">
            Nuestras Marcas
          </h2>
        </div>
        <div class="brands-marquee overflow-hidden py-2">
          <div class="brands-track flex w-max items-center gap-6 sm:gap-8 lg:gap-10">
            {[...brands, ...brands].map((brand, idx) => (
              <a
                href={`/productos?marca=${brand.slug}`}
                class="group flex shrink-0 flex-col items-center"
                aria-label={brand.name}
                aria-hidden={idx >= brands.length ? 'true' : 'false'}
              >
                <div class="flex h-28 w-28 items-center justify-center overflow-hidden rounded-full border-2 border-gray-200 bg-white p-3 shadow-sm transition-all group-hover:-translate-y-0.5 group-hover:border-red-500 group-hover:shadow-md sm:h-32 sm:w-32">
                  {brand.logo_url ? (
                    <img src={brand.logo_url} alt={brand.name} class="h-full w-full object-contain" loading="lazy" />
                  ) : (
                    <span class="text-sm font-bold text-gray-400 uppercase">{brand.name.slice(0, 3)}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Sección configurable: imagen + 4 cuadros -->
  {ceramicSection?.is_active !== false && (
    <section class="bg-gray-50 py-10 sm:py-14">
      <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
        <a href={ceramicLink} class="group block overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
          <img
            src={ceramicImage}
            alt={ceramicSection?.title || 'Destacado'}
            class="h-40 w-full object-cover transition-transform duration-300 group-hover:scale-105 sm:h-44 lg:h-52"
            loading="lazy"
          />
        </a>

        <div class="mt-6 grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4">
          {ceramicTiles.map((tile, idx) => (
            <a href={ceramicLink} class="group overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm" aria-label={`Tile ${idx + 1}`}>
              <img src={tile} alt={`Tile ${idx + 1}`} class="aspect-square w-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </a>
          ))}
        </div>

        <div class="mt-8 text-center">
          <a href={ceramicLink} class="inline-flex items-center gap-2 rounded-full bg-gray-900 px-8 py-3 text-sm font-bold text-white transition-colors hover:bg-gray-700">
            Ver más productos
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Sección: Envios -->
  <section class="bg-white py-10 sm:py-14">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 sm:p-8">
        <div class="text-center">
          <h2 class="text-3xl font-black uppercase text-gray-900 sm:text-5xl">
            Envíos <span class="text-red-600">a todo el Perú</span>
          </h2>
          <p class="mt-2 text-sm font-medium text-gray-600 sm:text-base">Rápidos, confiables y con seguimiento completo</p>
          <div class="mx-auto mt-3 h-1 w-28 rounded-full bg-red-600"></div>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          {[
            { title: 'Envíos diarios', desc: 'Realizamos envíos de lunes a sábado, excepto feriados.' },
            { title: 'Embalaje seguro', desc: 'Todos los pedidos son embalados cuidadosamente y etiquetados.' },
            { title: 'Agencia de transporte', desc: 'Llevamos tu pedido a agencias de transporte sin costo adicional.' },
            { title: 'Seguimiento completo', desc: 'Te enviamos la guía para que puedas hacer tracking y coordinar.' },
          ].map((item, idx) => (
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-4">
              <div class="mb-3 flex items-center gap-3">
                <div class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-full border border-gray-200 bg-white p-2 shadow-sm">
                  <img src={shippingIcons[idx] || shippingIcons[0]} alt={item.title} class="h-full w-full object-contain" loading="lazy" />
                </div>
                <p class="text-base font-extrabold uppercase text-gray-900">{item.title}</p>
              </div>
              <p class="text-sm text-gray-600">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Sección: Reseñas -->
  <section class="bg-white pb-12 sm:pb-16">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-black uppercase leading-tight text-gray-900 sm:text-5xl">
          Lo que dicen
          <br />
          <span class="text-red-600">nuestros clientes</span>
        </h2>
        <div class="mx-auto mt-3 h-1 w-28 rounded-full bg-red-600"></div>
      </div>

      <div class="mt-8 overflow-hidden">
        <div class="reviews-track flex w-max gap-4">
          {[...(homeReviews.length >= 10 ? homeReviews : Array.from({ length: 10 }).map((_, i) => ({
            id: `fallback-${i}`,
            author_name: `Cliente REBI ${i + 1}`,
            review_text: 'Excelente atención y entrega rápida. Productos de muy buena calidad.',
            stars: 5,
            display_order: i,
            is_active: true,
          }))), ...(homeReviews.length >= 10 ? homeReviews : Array.from({ length: 10 }).map((_, i) => ({
            id: `fallback-dup-${i}`,
            author_name: `Cliente REBI ${i + 1}`,
            review_text: 'Excelente atención y entrega rápida. Productos de muy buena calidad.',
            stars: 5,
            display_order: i,
            is_active: true,
          })))]
            .map((review, idx) => (
          <article class="w-[280px] shrink-0 rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            {review.attachment_url && (
              <div class="mb-3 overflow-hidden rounded-lg border border-gray-200">
                <img src={review.attachment_url} alt={`Adjunto de ${review.author_name}`} class="h-28 w-full object-cover" loading="lazy" />
              </div>
            )}
            <div class="mb-3 flex items-center gap-1 text-amber-400">
              {Array.from({ length: Math.max(1, Math.min(5, Number(review.stars) || 5)) }).map(() => (
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81H7.03a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="min-h-[88px] text-sm leading-6 text-gray-600">"{review.review_text}"</p>
            <div class="mt-5 flex items-center gap-2">
              {review.avatar_url ? (
                <img src={review.avatar_url} alt={review.author_name} class="h-8 w-8 rounded-full border border-gray-200 object-cover" loading="lazy" />
              ) : (
                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-red-50 text-red-500">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5.121 17.804A9 9 0 1118.88 17.8M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
              )}
              <div>
                <p class="text-xs font-bold uppercase tracking-wide text-gray-900">{review.author_name}</p>
                <p class="text-[11px] text-gray-400">Reseña #{idx + 1}</p>
              </div>
            </div>
          </article>
        ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-gray-900 py-12 sm:py-16">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
        <div>
          <h2 class="text-2xl font-extrabold text-white sm:text-3xl">¿Necesitás un presupuesto a medida?</h2>
          <p class="mt-2 text-gray-400">Nuestros asesores técnicos te ayudan a calcular los materiales para tu obra.</p>
        </div>
        <div class="flex flex-wrap gap-4">
          <a
            href="/productos"
            class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-rebi-red)] px-6 py-3 font-semibold text-white transition-colors hover:bg-red-700"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Ver catálogo
          </a>
          <a
            href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '5491112345678'}?text=${encodeURIComponent('Hola, necesito un presupuesto para mi obra')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white px-6 py-3 font-semibold text-white transition-colors hover:bg-white hover:text-gray-900"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            WhatsApp Ventas
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Ubicación -->
  <section class="bg-gray-100 py-12 sm:py-16">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-xl font-extrabold uppercase text-gray-900 sm:text-2xl">
        Nuestra ubicación
      </h2>

      <div class="grid gap-0 overflow-hidden rounded-2xl lg:grid-cols-5">
        <!-- Mapa -->
        <div class="lg:col-span-3">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3284.016887889529!2d-58.38375908477038!3d-34.60373888045953!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bccacf0d84b5b3%3A0x5c81e72752b6b02!2sAv.+9+de+Julio%2C+Buenos+Aires!5e0!3m2!1ses-419!2sar!4v1710000000000!5m2!1ses-419!2sar"
            width="100%"
            height="100%"
            style="border:0; min-height: 380px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Rebi Construcciones"
            class="h-full w-full"
          ></iframe>
        </div>

        <!-- Info card oscura -->
