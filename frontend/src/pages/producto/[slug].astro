---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ProductGallery from '../../components/ProductGallery';
import ProductTabs from '../../components/ProductTabs';
import ProductActions from '../../components/ProductActions';
import TrackProductView from '../../components/TrackProductView';
import { getProductBySlug, getProducts } from '../../lib/data';

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/productos');

const product = await getProductBySlug(slug);
if (!product) return Astro.redirect('/productos');

const related = await getProducts({ categorySlug: product.category?.slug, limit: 4 });
const relatedFiltered = related.filter((p) => p.id !== product.id).slice(0, 4);

const productImages = product.product_images ?? [];

const brandName = product.brand?.name;
const firstVariant = product.variants?.[0];

const whatsapp = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '5491112345678';
const whatsappUrl = `https://wa.me/${whatsapp}?text=${encodeURIComponent(`Hola, consulta por: ${product.name}`)}`;
---

<Layout
  title={`${product.name} | Rebi Construcciones`}
  description={product.description ?? product.name}
>
  <TrackProductView client:load product={product} />
  <div class="mx-auto max-w-[1400px] px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="transition-colors hover:text-red-600">Inicio</a>
      {product.category && (
        <>
          <span class="mx-2">&gt;</span>
          <a href={`/productos?categoria=${product.category.slug}`} class="transition-colors hover:text-red-600">
            {product.category.name}
          </a>
        </>
      )}
      <span class="mx-2">&gt;</span>
      <span class="font-medium text-gray-900">{product.name}</span>
    </nav>

    <!-- Product detail -->
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12">
      <!-- Gallery -->
      <div>
        <ProductGallery client:load productImages={productImages} fallbackUrl={product.image_url} productName={product.name} />
      </div>

      <!-- Info -->
      <div>
        {brandName && (
          <span class="mb-2 inline-block text-xs font-bold uppercase tracking-widest text-gray-500">
            {brandName}
          </span>
        )}

        <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl lg:text-4xl">{product.name}</h1>

        <div class="mt-3 flex flex-wrap items-center gap-3">
          {product.is_active ? (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-800">
              <span class="h-2 w-2 rounded-full bg-green-500"></span>
              STOCK DISPONIBLE
            </span>
          ) : (
            <span class="inline-flex items-center gap-1.5 rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-800">
              <span class="h-2 w-2 rounded-full bg-red-500"></span>
              SIN STOCK
            </span>
          )}
          {firstVariant?.sku && (
            <span class="text-xs text-gray-400">SKU: {firstVariant.sku}</span>
          )}
        </div>

        <!-- Variant selector + quantity + add to cart (React interactive) -->
        <div class="mt-8">
          <ProductActions client:load product={product} />
        </div>

        <!-- Shipping options -->
        <div class="mt-8 space-y-4 border-t border-gray-200 pt-6">
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-100 text-red-600">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900">Envío a domicilio</p>
              <p class="text-sm text-gray-500">Consultá costos según tu zona</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-100 text-red-600">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.15c0 .415.336.75.75.75z" />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-gray-900">Retiro en sucursal</p>
              <p class="text-sm text-gray-500">Disponible en todas nuestras sedes</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="mt-12 sm:mt-16">
      <ProductTabs
        client:load
        variants={product.variants}
        description={product.description}
        weightKg={product.weight_kg}
      />
    </div>

    <!-- Related products -->
    {relatedFiltered.length > 0 && (
      <section class="mt-12 sm:mt-16">
        <h2 class="mb-8 text-xl font-extrabold uppercase text-gray-900">Productos relacionados</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 sm:gap-6">
          {relatedFiltered.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
