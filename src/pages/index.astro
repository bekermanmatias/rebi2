---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import OffersBanner from '../components/OffersBanner';
import RecentlyViewed from '../components/RecentlyViewed';
import { getCategories, getProducts, getBanners, getPromoCards } from '../lib/data';

const categories = await getCategories();
const products = await getProducts({ limit: 4 });
const banners = await getBanners();
const promoCards = await getPromoCards();

const cards = promoCards.filter((p) => p.layout_type === 'card');
const promoBanners = promoCards.filter((p) => p.layout_type === 'banner');

const categoryIcons: Record<string, string> = {
  construction: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2 22h20M12 2L2 12h3v8h6v-6h2v6h6v-8h3L12 2z"/></svg>`,
  paintbrush: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>`,
  wrench: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"/></svg>`,
  droplet: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a8 8 0 008-8c0-4.5-8-13-8-13S4 8.5 4 13a8 8 0 008 8z"/></svg>`,
  zap: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
  palette: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z"/></svg>`,
  grid: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>`,
  home: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>`,
  box: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>`,
};

const slugToIcon: Record<string, string> = {
  'obra-gruesa': 'construction',
  'terminaciones': 'paintbrush',
  'herramientas': 'wrench',
  'plomeria': 'droplet',
  'electricidad': 'zap',
  'pinturas': 'palette',
  'pisos': 'grid',
  'cocinas': 'home',
};
---

<Layout
  title="Rebi Construcciones - Materiales para tu obra"
  description="Referentes en la comercialización de materiales para la construcción. Calidad, servicio y compromiso con cada obra."
>
  <!-- Offers banner carousel -->
  {banners.length > 0 && (
    <section>
      <OffersBanner client:load banners={banners} />
    </section>
  )}

  <!-- Promo cards -->
  {promoCards.length > 0 && (
    <section class="bg-gray-100 py-8 sm:py-10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        {cards.length > 0 && (
          <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-4">
            {cards.map((card) => (
              <a href={card.target_link} class="group relative flex flex-col justify-end overflow-hidden rounded-2xl shadow-md transition-transform hover:-translate-y-1 hover:shadow-lg">
                <img
                  src={card.image_url}
                  alt={card.title}
                  class="absolute inset-0 h-full w-full object-cover"
                  loading="lazy"
                />
                <div class="relative z-10 flex aspect-[4/5] flex-col justify-between bg-gradient-to-t from-black/60 via-black/20 to-transparent p-4 sm:p-5">
                  <p class="text-xs font-semibold uppercase tracking-wide text-white/80">{card.title}</p>
                  <div>
                    {card.discount_badge && (
                      <div class="inline-flex items-baseline gap-2 rounded-lg bg-white/90 px-3 py-1.5 backdrop-blur-sm">
                        <span class="text-2xl font-black text-red-600 sm:text-3xl">{card.discount_badge}</span>
                        <span class="text-xs font-bold uppercase text-gray-800 sm:text-sm">{card.title}</span>
                      </div>
                    )}
                    {card.subtitle && (
                      <p class="mt-2 text-[10px] font-semibold uppercase tracking-wide text-white/70 sm:text-xs">{card.subtitle}</p>
                    )}
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}

        {promoBanners.map((banner) => (
          <a href={banner.target_link} class="group mt-4 block overflow-hidden rounded-2xl shadow-md transition-transform hover:-translate-y-0.5 hover:shadow-lg">
            <div class="relative">
              <img
                src={banner.image_url}
                alt={banner.title}
                class="h-full w-full object-cover"
                style="min-height: 160px; max-height: 280px;"
                loading="lazy"
              />
              <div class="absolute inset-0 flex items-center justify-between bg-gradient-to-r from-black/50 to-transparent px-6 sm:px-10">
                <div>
                  {banner.discount_badge && (
                    <>
                      <p class="text-xs font-bold uppercase tracking-wider text-white/70 sm:text-sm">Hasta</p>
                      <p class="text-5xl font-black text-white sm:text-7xl">{banner.discount_badge}</p>
                    </>
                  )}
                  <p class="text-lg font-extrabold uppercase tracking-wide text-white sm:text-2xl">{banner.title}</p>
                  {banner.subtitle && (
                    <p class="mt-1 text-[10px] uppercase text-white/60 sm:text-xs">{banner.subtitle}</p>
                  )}
                </div>
                <div class="hidden text-right sm:block">
                  <span class="rounded-full bg-white/90 px-6 py-3 text-sm font-bold uppercase text-gray-900 shadow transition-colors group-hover:bg-white">
                    Ver productos →
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Grilla de promos por categoría -->
  <section class="bg-white py-8 sm:py-10">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-lg font-extrabold text-gray-900 sm:text-xl">
        Completá tu proyecto y ahorrá: Construcción y más
      </h2>

      <div class="grid grid-cols-2 grid-rows-2 gap-3 sm:gap-4 lg:grid-cols-4 lg:grid-rows-2">
        <!-- Pinturas (arriba izq) -->
        <a href="/productos?categoria=pinturas" class="group relative overflow-hidden rounded-2xl shadow-md transition-transform hover:-translate-y-0.5 hover:shadow-lg">
          <img src="https://images.unsplash.com/photo-1562259949-e8e7689d7828?q=80&w=800&auto=format&fit=crop" alt="Pinturas" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
          <div class="relative flex aspect-[4/3] flex-col justify-end bg-gradient-to-t from-black/60 to-transparent p-4">
            <p class="text-base font-extrabold text-white sm:text-lg">Pinturas</p>
            <span class="mt-1 inline-block w-fit rounded bg-yellow-400 px-2 py-0.5 text-[10px] font-bold text-gray-900 sm:text-xs">Sumá $200.000 y ahorrá 20%</span>
          </div>
        </a>

        <!-- Cerámicos (centro, ocupa 2 filas) -->
        <a href="/productos?categoria=pisos" class="group relative overflow-hidden rounded-2xl shadow-md transition-transform hover:-translate-y-0.5 hover:shadow-lg lg:col-start-2 lg:col-end-4 lg:row-span-2">
          <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?q=80&w=1200&auto=format&fit=crop" alt="Cerámicos y porcelanatos" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
          <div class="relative flex aspect-[4/3] flex-col items-center justify-center bg-black/30 p-4 text-center lg:aspect-auto lg:h-full">
            <p class="text-xl font-black text-white sm:text-3xl">Cerámicos y<br/>porcelanatos</p>
            <span class="mt-3 inline-block rounded bg-yellow-400 px-4 py-1.5 text-xs font-bold text-gray-900 sm:text-sm">Sumá $200.000 y ahorrá 20%</span>
          </div>
        </a>

        <!-- Ferretería y electricidad (arriba der) -->
        <a href="/productos?categoria=electricidad" class="group relative overflow-hidden rounded-2xl shadow-md transition-transform hover:-translate-y-0.5 hover:shadow-lg">
          <img src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?q=80&w=800&auto=format&fit=crop" alt="Ferretería y electricidad" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
          <div class="relative flex aspect-[4/3] flex-col justify-start bg-gradient-to-b from-black/60 to-transparent p-4">
            <p class="text-base font-extrabold text-white sm:text-lg">Ferretería y<br/>electricidad</p>
            <span class="mt-1 inline-block w-fit rounded bg-yellow-400 px-2 py-0.5 text-[10px] font-bold text-gray-900 sm:text-xs">Sumá $200.000 y ahorrá 20%</span>
          </div>
        </a>

        <!-- Materiales de construcción (abajo izq) -->
        <a href="/productos?categoria=obra-gruesa" class="group relative overflow-hidden rounded-2xl shadow-md transition-transform hover:-translate-y-0.5 hover:shadow-lg">
          <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=800&auto=format&fit=crop" alt="Materiales de construcción" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
          <div class="relative flex aspect-[4/3] flex-col justify-end bg-gradient-to-t from-black/60 to-transparent p-4">
            <p class="text-base font-extrabold text-white sm:text-lg">Materiales de<br/>construcción</p>
            <span class="mt-1 inline-block w-fit rounded bg-yellow-400 px-2 py-0.5 text-[10px] font-bold text-gray-900 sm:text-xs">Sumá $200.000 y ahorrá 20%</span>
          </div>
        </a>

        <!-- Plomería (abajo der) -->
        <a href="/productos?categoria=plomeria" class="group relative overflow-hidden rounded-2xl shadow-md transition-transform hover:-translate-y-0.5 hover:shadow-lg">
          <img src="https://images.unsplash.com/photo-1585704032915-c3400ca199e7?q=80&w=800&auto=format&fit=crop" alt="Plomería" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
          <div class="relative flex aspect-[4/3] flex-col justify-end bg-gradient-to-t from-black/60 to-transparent p-4">
            <p class="text-base font-extrabold text-white sm:text-lg">Plomería</p>
            <span class="mt-1 inline-block w-fit rounded bg-yellow-400 px-2 py-0.5 text-[10px] font-bold text-gray-900 sm:text-xs">Sumá $200.000 y ahorrá 20%</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Category icons strip - navegación rápida -->
  <section class="border-b border-gray-200 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <div class="mb-4 flex items-center justify-between gap-4">
        <h2 class="text-lg font-extrabold uppercase text-gray-900 sm:text-xl">
          Categorias Destacadas
        </h2>
      </div>
      <div class="flex items-center gap-6 overflow-x-auto pb-3 scrollbar-hide sm:justify-center sm:gap-8 lg:gap-12">
        {categories.map((cat) => {
          const iconKey = slugToIcon[cat.slug] ?? 'box';
          return (
            <a
              href={`/productos?categoria=${cat.slug}`}
              class="group flex shrink-0 flex-col items-center gap-3 text-center"
            >
              <div class="flex h-20 w-20 items-center justify-center rounded-full border-2 border-gray-200 bg-gray-50 text-gray-600 shadow-sm transition-all group-hover:-translate-y-0.5 group-hover:border-red-500 group-hover:bg-red-50 group-hover:text-red-600 group-hover:shadow-md sm:h-24 sm:w-24">
                <Fragment set:html={categoryIcons[iconKey] ?? categoryIcons.box} />
              </div>
              <span class="text-xs font-semibold uppercase tracking-wide text-gray-700 group-hover:text-red-600">
                {cat.name}
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Últimos vistos -->
  <RecentlyViewed client:load />

  <!-- Featured products -->
  <section class="bg-gray-50 py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-extrabold uppercase italic text-gray-900 sm:text-2xl">
          Destacados de la semana
        </h2>
        <a
          href="/productos"
          class="flex items-center gap-1 text-sm font-semibold text-red-600 transition-colors hover:text-red-700"
        >
          Ver todo
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4 sm:gap-6">
        {products.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-gray-900 py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
        <div>
          <h2 class="text-2xl font-extrabold text-white sm:text-3xl">¿Necesitás un presupuesto a medida?</h2>
          <p class="mt-2 text-gray-400">Nuestros asesores técnicos te ayudan a calcular los materiales para tu obra.</p>
        </div>
        <div class="flex flex-wrap gap-4">
          <a
            href="/productos"
            class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-rebi-red)] px-6 py-3 font-semibold text-white transition-colors hover:bg-red-700"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Ver catálogo
          </a>
          <a
            href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '5491112345678'}?text=${encodeURIComponent('Hola, necesito un presupuesto para mi obra')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-white px-6 py-3 font-semibold text-white transition-colors hover:bg-white hover:text-gray-900"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            WhatsApp Ventas
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Ubicación -->
  <section class="bg-gray-100 py-12 sm:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-xl font-extrabold uppercase text-gray-900 sm:text-2xl">
        Nuestra ubicación
      </h2>

      <div class="grid gap-0 overflow-hidden rounded-2xl lg:grid-cols-5">
        <!-- Mapa -->
        <div class="lg:col-span-3">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3284.016887889529!2d-58.38375908477038!3d-34.60373888045953!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bccacf0d84b5b3%3A0x5c81e72752b6b02!2sAv.+9+de+Julio%2C+Buenos+Aires!5e0!3m2!1ses-419!2sar!4v1710000000000!5m2!1ses-419!2sar"
            width="100%"
            height="100%"
            style="border:0; min-height: 380px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación de Rebi Construcciones"
            class="h-full w-full"
          ></iframe>
        </div>

        <!-- Info card oscura -->
        <div class="flex flex-col justify-center gap-6 bg-gray-900 p-8 lg:col-span-2 lg:p-10">
          <div class="flex items-start gap-4">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-red-500">Dirección</p>
              <p class="mt-1 text-sm leading-relaxed text-gray-300">
                Av. de los Trabajadores 4500,<br/>
                B1650 San Martín, Provincia de Buenos Aires
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <svg class="mt-0.5 h-5 w-5 shrink-0 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-red-500">Horarios de atención</p>
