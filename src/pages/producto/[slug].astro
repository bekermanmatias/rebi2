---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getProductBySlug, getProducts } from '../../lib/data';

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/productos');

const product = await getProductBySlug(slug);
if (!product) return Astro.redirect('/productos');

const related = await getProducts({ categorySlug: product.category?.slug, limit: 4 });
const relatedFiltered = related.filter((p) => p.id !== product.id).slice(0, 4);

const priceFormatted =
  product.price != null
    ? new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS' }).format(product.price)
    : null;

const whatsapp = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '5491112345678';
const whatsappUrl = `https://wa.me/${whatsapp}?text=${encodeURIComponent(`Hola, consulta por: ${product.name}`)}`;
---

<Layout
  title={`${product.name} | Corralón`}
  description={product.description ?? product.name}
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <nav class="mb-8 text-sm text-stone-500">
      <a href="/" class="hover:text-stone-700">Inicio</a>
      <span class="mx-2">/</span>
      <a href="/productos" class="hover:text-stone-700">Productos</a>
      {product.category && (
        <>
          <span class="mx-2">/</span>
          <a href={`/productos?categoria=${product.category.slug}`} class="hover:text-stone-700">
            {product.category.name}
          </a>
        </>
      )}
      <span class="mx-2">/</span>
      <span class="text-stone-900">{product.name}</span>
    </nav>

    <div class="grid gap-12 lg:grid-cols-2">
      <div class="aspect-square overflow-hidden rounded-xl border border-stone-200 bg-stone-100">
        {product.image_url ? (
          <img
            src={product.image_url}
            alt={product.name}
            class="h-full w-full object-cover"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-stone-400">
            <svg class="h-32 w-32" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
        )}
      </div>

      <div>
        {product.category && (
          <a
            href={`/productos?categoria=${product.category.slug}`}
            class="mb-2 inline-block text-xs font-medium uppercase tracking-wider text-amber-600 hover:text-amber-700"
          >
            {product.category.name}
          </a>
        )}
        <h1 class="text-3xl font-bold text-stone-900 sm:text-4xl">{product.name}</h1>
        {priceFormatted ? (
          <p class="mt-4 text-2xl font-bold text-stone-900">{priceFormatted}</p>
        ) : (
          <p class="mt-4 text-stone-600">Consultar precio</p>
        )}
        {product.description && (
          <div class="mt-6 text-stone-600">
            <h2 class="mb-2 font-semibold text-stone-900">Descripción</h2>
            <p class="whitespace-pre-wrap">{product.description}</p>
          </div>
        )}
        <div class="mt-8 flex flex-wrap gap-4">
          <button
            type="button"
            class="add-to-cart inline-flex items-center gap-2 rounded-lg bg-amber-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-amber-700"
            data-product-id={product.id}
            data-product-slug={product.slug}
            data-product-name={product.name}
            data-product-price={product.price ?? 0}
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            Agregar al carrito
          </button>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg border-2 border-stone-300 px-6 py-3 font-semibold text-stone-700 transition-colors hover:border-stone-400 hover:bg-stone-50"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
            Consultar por WhatsApp
          </a>
        </div>
      </div>
    </div>

    {relatedFiltered.length > 0 && (
      <section class="mt-20">
        <h2 class="mb-8 text-2xl font-bold text-stone-900">Productos relacionados</h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {relatedFiltered.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
