---
import Layout from '../../layouts/Layout.astro';
import CatalogWithFilters from '../../components/CatalogWithFilters';
import { getCategories, getProducts } from '../../lib/data';

const [categories, products] = await Promise.all([
  getCategories(),
  getProducts(),
]);
---

<Layout
  title="Productos | Corralón"
  description="Catálogo de materiales de construcción. Obra gruesa, terminaciones y herramientas."
>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-stone-900">Catálogo de productos</h1>
      <p class="mt-2 text-stone-600">Filtrá por categoría o buscá por nombre</p>
    </div>

    <CatalogWithFilters client:load products={products} categories={categories} />
  </div>
</Layout>
