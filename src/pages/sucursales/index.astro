---
import Layout from '../../layouts/Layout.astro';

const sucursales = [
  {
    nombre: 'REBI - Av. Mártires de Uchuraccay',
    direccion: 'Av. Mártires de Uchuraccay 2482, MOLLEPAMPA',
    mapsQuery: 'Av. Mártires de Uchuraccay 2482, Mollepampa',
  },
  {
    nombre: 'REBI - Av. Hoyos Rubio',
    direccion: 'María de Nararet, Av. Hoyos Rubio 872, Cajamarca',
    mapsQuery: 'Av. Hoyos Rubio 872, Cajamarca',
  },
];
---

<Layout
  title="Sucursales | Rebi Construcciones"
  description="Encontrá nuestras sucursales. REBI Av. Mártires de Uchuraccay (Mollepampa) y REBI Av. Hoyos Rubio (Cajamarca)."
>
  <div class="mx-auto max-w-[1400px] px-4 py-8 sm:px-6 sm:py-12 lg:px-8">
    <nav class="mb-6 text-sm text-gray-500">
      <a href="/" class="transition-colors hover:text-red-600">Inicio</a>
      <span class="mx-2">&gt;</span>
      <span class="font-medium text-gray-900">Sucursales</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl">Nuestras sucursales</h1>
    <p class="mt-2 text-gray-600">Visitános en cualquiera de nuestras ubicaciones.</p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:gap-8">
      {sucursales.map((suc) => (
        <article class="flex flex-col overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
          <div class="flex flex-1 flex-col p-6 sm:p-8">
            <h2 class="text-lg font-bold text-gray-900">{suc.nombre}</h2>
            <div class="mt-4 flex items-start gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-100 text-red-600">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <p class="text-sm leading-relaxed text-gray-700">{suc.direccion}</p>
            </div>
            <a
              href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(suc.mapsQuery)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex w-fit items-center gap-2 rounded-lg bg-red-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-red-700"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Cómo llegar
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>
